<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <title>Wunschliste</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@600;700;900&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#F5F4F1;--surface:#FFFFFF;--s2:#EEECEA;--border:#E0DDD8;
      --text:#1A1916;--muted:#8A8880;--dim:#C8C5C0;
      --green:#1A9862;--orange:#D97706;--red:#DC2626;--blue:#2563EB;
      --radius:14px;--shadow:0 1px 8px rgba(0,0,0,0.06);
    }
    body.dark{--bg:#141416;--surface:#1E1E22;--s2:#252528;--border:#303035;--text:#EDECEA;--muted:#72706A;--dim:#404040}
    html,body{min-height:100%;background:var(--bg);font-family:'Barlow',sans-serif;color:var(--text);-webkit-font-smoothing:antialiased;transition:background .3s,color .3s}
    .page{max-width:1100px;margin:0 auto;padding:28px 22px 80px;display:flex;flex-direction:column;gap:18px}

    /* TOPBAR */
    .topbar{display:flex;align-items:center;justify-content:space-between;gap:12px}
    .topbar-left{display:flex;align-items:baseline;gap:14px}
    .topbar-left h1{font-family:'Barlow Condensed',sans-serif;font-size:34px;font-weight:900;letter-spacing:-.01em;line-height:1}
    .topbar-left p{font-size:12px;color:var(--muted)}
    .topbar-right{display:flex;align-items:center;gap:8px}
    .back-btn{font-size:12px;font-weight:500;color:var(--muted);text-decoration:none;padding:6px 12px;border:1px solid var(--border);border-radius:8px;transition:color .15s,border-color .15s}
    .back-btn:hover{color:var(--text);border-color:var(--text)}
    .theme-toggle{width:44px;height:24px;background:var(--border);border:none;border-radius:100px;cursor:pointer;position:relative;transition:background .3s;flex-shrink:0}
    .theme-toggle::after{content:'☀️';position:absolute;top:2px;left:2px;width:20px;height:20px;border-radius:50%;background:var(--surface);font-size:11px;line-height:20px;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.2);transition:transform .3s cubic-bezier(.34,1.56,.64,1)}
    body.dark .theme-toggle::after{content:'🌙';transform:translateX(20px)}

    /* FINANCE BANNER */
    .finance-banner{
      background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
      box-shadow:var(--shadow);padding:12px 20px;cursor:pointer;
      display:flex;align-items:center;gap:16px;flex-wrap:wrap;
      transition:border-color .2s;user-select:none;
    }
    .finance-banner:hover{border-color:var(--muted)}
    .fb-stat{display:flex;align-items:center;gap:8px;flex-shrink:0}
    .fb-label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);white-space:nowrap}
    .fb-val{font-family:'DM Mono',monospace;font-size:18px;font-weight:500;line-height:1}
    .fb-val.great{color:var(--green)} .fb-val.good{color:#4caf7d}
    .fb-val.neutral{color:var(--muted)} .fb-val.warning{color:var(--orange)} .fb-val.negative{color:var(--red)}
    .fb-divider{width:1px;height:28px;background:var(--border);flex-shrink:0}
    .fb-prognose{flex:1;min-width:200px;display:flex;align-items:center;gap:8px}
    .fb-prog-bar{flex:1;height:5px;background:var(--border);border-radius:99px;overflow:hidden;min-width:80px}
    .fb-prog-fill{height:100%;border-radius:99px;transition:width .5s,background .3s}
    .fb-prog-label{font-size:11px;color:var(--muted);white-space:nowrap}
    .fb-chevron{font-size:16px;color:var(--muted);margin-left:auto;transition:transform .25s}
    .fb-chevron.open{transform:rotate(90deg)}

    /* FINANCE DETAIL PANEL */
    .finance-detail{
      background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
      box-shadow:var(--shadow);padding:20px 22px;display:flex;flex-direction:column;gap:16px;
    }
    .finance-detail[hidden]{display:none}
    .fd-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px}
    .fd-stat{display:flex;flex-direction:column;gap:4px;padding:14px;background:var(--s2);border-radius:10px;border:1px solid var(--border)}
    .fd-label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .fd-val{font-family:'DM Mono',monospace;font-size:24px;font-weight:500;color:var(--text);line-height:1}
    .fd-sub{font-size:11px;color:var(--muted);margin-top:2px}
    .insight-box{padding:14px 16px;border-radius:10px;border:1px solid;font-size:13px;line-height:1.6}
    .insight-box.ok{background:rgba(26,152,98,.07);border-color:rgba(26,152,98,.25);color:var(--green)}
    .insight-box.warn{background:rgba(217,119,6,.07);border-color:rgba(217,119,6,.25);color:var(--orange)}
    .insight-box.bad{background:rgba(220,38,38,.07);border-color:rgba(220,38,38,.25);color:var(--red)}
    .insight-box strong{font-weight:700}
    .sparrate-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .sparrate-label{font-size:11px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--muted)}
    .sparrate-input{font-family:'DM Mono',monospace;font-size:20px;font-weight:500;background:transparent;border:none;border-bottom:1.5px solid var(--border);color:var(--text);width:80px;outline:none;transition:border-color .15s;padding:0 2px}
    .sparrate-input:focus{border-color:var(--text)}
    .sparrate-input::-webkit-outer-spin-button,.sparrate-input::-webkit-inner-spin-button{-webkit-appearance:none}
    .sparrate-save{padding:5px 12px;border-radius:7px;border:1px solid var(--border);background:transparent;font-size:12px;font-weight:500;color:var(--muted);cursor:pointer;transition:all .15s}
    .sparrate-save:hover{border-color:var(--text);color:var(--text)}
    .sparrate-save.saved{border-color:var(--green);color:var(--green)}

    /* BUDGET CARD */
    .budget-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;box-shadow:var(--shadow);display:flex;flex-direction:column;gap:12px}
    .budget-row{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
    .budget-field{display:flex;align-items:center;gap:7px;background:var(--s2);border:1.5px solid var(--border);border-radius:9px;padding:6px 11px;transition:border-color .15s}
    .budget-field:focus-within{border-color:var(--text)}
    .budget-label{font-size:10px;color:var(--muted);white-space:nowrap;text-transform:uppercase;letter-spacing:.05em}
    .budget-input{background:transparent;border:none;outline:none;font-family:'DM Mono',monospace;font-size:17px;font-weight:500;color:var(--text);width:72px;text-align:right}
    .budget-input::-webkit-outer-spin-button,.budget-input::-webkit-inner-spin-button{-webkit-appearance:none}
    .budget-unit{font-size:11px;color:var(--muted)}
    .budget-bar-wrap{flex:1;min-width:180px;display:flex;flex-direction:column;gap:4px}
    .budget-bar-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--muted)}
    .budget-bar-track{height:5px;background:var(--border);border-radius:99px;overflow:hidden}
    .budget-bar-fill{height:100%;border-radius:99px;transition:width .5s,background .3s}
    .budget-summary{font-size:12px;color:var(--muted)}
    .budget-summary strong{color:var(--text)}

    /* SORT BAR */
    .sort-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .sort-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
    .sort-btn{padding:5px 11px;border-radius:7px;border:1px solid var(--border);background:transparent;font-size:12px;font-weight:500;color:var(--muted);cursor:pointer;transition:all .15s}
    .sort-btn.active{background:var(--text);color:var(--bg);border-color:var(--text)}
    .filter-tag{padding:4px 10px;border-radius:99px;border:1px solid var(--border);background:transparent;font-size:11px;color:var(--muted);cursor:pointer;transition:all .15s}
    .filter-tag.active{background:var(--s2);border-color:var(--muted);color:var(--text)}
    .spacer{flex:1}
    .items-count{font-size:12px;color:var(--muted);font-family:'DM Mono',monospace}
    .add-btn{display:flex;align-items:center;gap:7px;padding:8px 16px;border-radius:9px;border:1.5px dashed var(--border);background:transparent;font-family:'Barlow',sans-serif;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s}
    .add-btn:hover{border-color:var(--text);color:var(--text);background:var(--s2)}

    /* ITEMS GRID */
    .items-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}

    /* ITEM CARD */
    .item-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;display:flex;flex-direction:column;transition:box-shadow .2s,transform .2s;position:relative}
    .item-card:hover{box-shadow:0 4px 20px rgba(0,0,0,.1);transform:translateY(-2px)}
    .item-rank{position:absolute;top:10px;left:10px;width:26px;height:26px;border-radius:50%;background:var(--text);color:var(--bg);font-family:'DM Mono',monospace;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;z-index:2}
    .item-rank.top{background:#D4AF37;color:#fff}
    .item-img{width:100%;height:150px;background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:40px;overflow:hidden}
    .item-img img{width:100%;height:100%;object-fit:cover}
    .item-body{padding:13px;display:flex;flex-direction:column;gap:7px}
    .item-name{font-family:'Barlow Condensed',sans-serif;font-size:19px;font-weight:700;line-height:1.1}
    .item-cat{font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--muted)}
    .item-price-row{display:flex;align-items:baseline;justify-content:space-between}
    .item-price{font-family:'DM Mono',monospace;font-size:20px;font-weight:500}
    .item-cpd{font-size:11px;color:var(--muted)}
    .item-score-bar{height:3px;border-radius:99px;background:var(--border);overflow:hidden}
    .item-score-fill{height:100%;border-radius:99px;background:var(--text);transition:width .5s}
    .item-meta{display:flex;align-items:center;justify-content:space-between}
    .item-score-label{font-size:10px;color:var(--muted)}
    .item-score-val{font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--text)}
    .item-badges{display:flex;gap:5px;flex-wrap:wrap}
    .badge{display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:3px 8px;border-radius:99px;font-weight:500;border:1px solid}
    .badge.wait{background:var(--s2);border-color:var(--border);color:var(--muted)}
    .badge.wait-done{background:rgba(26,152,98,.1);border-color:rgba(26,152,98,.3);color:var(--green)}
    .badge.can-buy{background:rgba(26,152,98,.1);border-color:rgba(26,152,98,.3);color:var(--green)}
    .badge.cant-buy{background:rgba(220,38,38,.07);border-color:rgba(220,38,38,.2);color:var(--red)}
    .badge.months{background:rgba(37,99,235,.07);border-color:rgba(37,99,235,.2);color:var(--blue)}
    .item-note{font-size:11px;color:var(--muted);line-height:1.5}
    .item-actions{display:flex;gap:5px;padding:10px 13px;border-top:1px solid var(--border)}
    .item-btn{flex:1;padding:6px;border-radius:7px;border:1px solid var(--border);background:transparent;font-family:'Barlow',sans-serif;font-size:11px;font-weight:500;color:var(--muted);cursor:pointer;transition:all .15s;text-decoration:none;text-align:center}
    .item-btn:hover{border-color:var(--text);color:var(--text)}
    .item-btn.danger:hover{border-color:var(--red);color:var(--red)}
    .item-btn.buy{background:var(--text);color:var(--bg);border-color:var(--text)}
    .item-btn.buy:hover{opacity:.8}
    .item-card.bought{opacity:.5}
    .item-rank.bought-rank{background:var(--green)}

    /* SECTION */
    .section-title{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:8px}
    .section-title::after{content:'';flex:1;height:1px;background:var(--border)}

    /* EMPTY */
    .empty{display:flex;flex-direction:column;align-items:center;gap:10px;padding:50px 20px;color:var(--muted);text-align:center;grid-column:1/-1}
    .empty-icon{font-size:44px}
    .empty-title{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:700;color:var(--dim)}

    /* MODAL */
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:100;display:flex;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(4px);opacity:0;pointer-events:none;transition:opacity .25s}
    .modal-overlay.open{opacity:1;pointer-events:all}
    .modal{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:26px;width:100%;max-width:500px;max-height:90vh;overflow-y:auto;display:flex;flex-direction:column;gap:16px;box-shadow:0 24px 60px rgba(0,0,0,.2);transform:translateY(20px);transition:transform .25s;position:relative}
    .modal-overlay.open .modal{transform:translateY(0)}
    .modal-title{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:900}
    .modal-close{position:absolute;top:18px;right:18px;width:30px;height:30px;border-radius:50%;border:1px solid var(--border);background:var(--s2);cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:all .15s}
    .modal-close:hover{color:var(--text)}
    .field{display:flex;flex-direction:column;gap:5px}
    .field label{font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--muted)}
    .field input,.field textarea,.field select{background:var(--s2);border:1.5px solid var(--border);border-radius:9px;padding:9px 12px;font-family:'Barlow',sans-serif;font-size:14px;color:var(--text);outline:none;transition:border-color .15s;width:100%}
    .field input:focus,.field textarea:focus{border-color:var(--text)}
    .field textarea{resize:vertical;min-height:55px}
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .img-preview{width:100%;height:140px;border:2px dashed var(--border);border-radius:11px;display:flex;align-items:center;justify-content:center;overflow:hidden;cursor:pointer;transition:border-color .15s}
    .img-preview:hover{border-color:var(--text)}
    .img-preview img{width:100%;height:100%;object-fit:cover}
    .img-placeholder{display:flex;flex-direction:column;align-items:center;gap:5px;color:var(--muted);font-size:12px}
    .tag-row{display:flex;gap:5px;flex-wrap:wrap}
    .tag{padding:4px 11px;border-radius:99px;border:1.5px solid var(--border);background:transparent;font-size:12px;font-weight:500;color:var(--muted);cursor:pointer;transition:all .15s}
    .tag.active{border-color:var(--text);background:var(--text);color:var(--bg)}
    .score-grid{display:flex;flex-direction:column;gap:8px}
    .score-row{display:flex;align-items:center;gap:9px}
    .score-name{font-size:11px;font-weight:500;color:var(--muted);width:85px;flex-shrink:0}
    .score-slider{flex:1;-webkit-appearance:none;appearance:none;height:4px;border-radius:99px;background:var(--border);outline:none;cursor:pointer}
    .score-slider::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--text);cursor:pointer}
    .score-val{font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--text);width:18px;text-align:right}
    .score-total{display:flex;align-items:center;justify-content:space-between;padding:9px 13px;background:var(--s2);border-radius:9px}
    .modal-submit{padding:11px;border-radius:10px;border:none;background:var(--text);font-family:'Barlow',sans-serif;font-size:14px;font-weight:700;color:var(--bg);cursor:pointer;transition:opacity .15s}
    .modal-submit:hover{opacity:.85}

    @keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    .item-card{animation:fadeUp .3s ease both}

    /* TABS */
    .tabs{display:flex;gap:4px;background:var(--s2);border-radius:11px;padding:4px}
    .tab-btn{flex:1;padding:8px 16px;border-radius:8px;border:none;background:transparent;font-family:'Barlow',sans-serif;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s;-webkit-tap-highlight-color:transparent}
    .tab-btn.active{background:var(--surface);color:var(--text);box-shadow:0 1px 4px rgba(0,0,0,.08)}

    /* PLAN AUSGABEN */
    .plan-list{display:flex;flex-direction:column;gap:10px}
    .plan-item{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:14px;box-shadow:var(--shadow)}
    .plan-item.urgent{border-color:rgba(220,38,38,.3);background:rgba(220,38,38,.03)}
    .plan-item.soon{border-color:rgba(217,119,6,.3);background:rgba(217,119,6,.03)}
    .plan-item.ok{border-color:rgba(26,152,98,.2);background:rgba(26,152,98,.02)}
    .plan-emoji{font-size:24px;flex-shrink:0;width:36px;text-align:center}
    .plan-body{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px}
    .plan-name{font-size:15px;font-weight:600;color:var(--text)}
    .plan-date{font-size:11px;color:var(--muted)}
    .plan-price{font-family:'DM Mono',monospace;font-size:20px;font-weight:500;color:var(--text);flex-shrink:0}
    .plan-days{font-size:11px;padding:3px 9px;border-radius:99px;font-weight:600;flex-shrink:0;white-space:nowrap}
    .plan-days.urgent{background:rgba(220,38,38,.1);color:var(--red)}
    .plan-days.soon{background:rgba(217,119,6,.1);color:var(--orange)}
    .plan-days.ok{background:rgba(26,152,98,.1);color:var(--green)}
    .plan-days.future{background:var(--s2);color:var(--muted)}
    .plan-actions{display:flex;gap:5px;flex-shrink:0}
    .plan-total-bar{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;box-shadow:var(--shadow)}
    .plan-total-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--muted)}
    .plan-total-val{font-family:'DM Mono',monospace;font-size:22px;font-weight:500;color:var(--text)}
    .plan-total-sub{font-size:11px;color:var(--muted)}

    /* PLAN MODAL */
    .plan-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:100;display:flex;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(4px);opacity:0;pointer-events:none;transition:opacity .25s}
    .plan-modal-overlay.open{opacity:1;pointer-events:all}
    .plan-modal{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:24px;width:100%;max-width:420px;display:flex;flex-direction:column;gap:15px;box-shadow:0 24px 60px rgba(0,0,0,.2);transform:translateY(16px);transition:transform .25s;position:relative}
    .plan-modal-overlay.open .plan-modal{transform:translateY(0)}

    @media(max-width:600px){
      .page{padding:16px 14px 60px;gap:14px}
      .topbar-left h1{font-size:26px}
      .two-col{grid-template-columns:1fr}
      .items-grid{grid-template-columns:1fr}
      .fd-grid{grid-template-columns:1fr 1fr}
      .finance-banner{gap:10px}
      .plan-item{flex-wrap:wrap}
    }
  </style>
</head>
<body>
<div class="page">

  <!-- Topbar -->
  <div class="topbar">
    <div class="topbar-left">
      <h1>🛒 Wunschliste</h1>
      <p id="topbar-sub">lädt…</p>
    </div>
    <div class="topbar-right">
      <a href="index.html" class="back-btn">← Zurück</a>
      <button class="theme-toggle" id="theme-toggle"></button>
    </div>
  </div>

  <!-- Finance Banner (collapsible) -->
  <div class="finance-banner" id="finance-banner" onclick="toggleFinanceDetail()">
    <div class="fb-stat">
      <span class="fb-label">Pro Tag</span>
      <span class="fb-val" id="fb-daily">—</span>
    </div>
    <div class="fb-divider"></div>
    <div class="fb-stat">
      <span class="fb-label">Sparrate</span>
      <span class="fb-val" id="fb-sparrate" style="color:var(--text)">—</span>
    </div>
    <div class="fb-divider"></div>
    <div class="fb-prognose">
      <div class="fb-prog-bar">
        <div class="fb-prog-fill" id="fb-prog-fill" style="width:0%"></div>
      </div>
      <span class="fb-prog-label" id="fb-prog-label">Prognose lädt…</span>
    </div>
    <span class="fb-chevron" id="fb-chevron">›</span>
  </div>

  <!-- Finance Detail Panel -->
  <div class="finance-detail" id="finance-detail" hidden>
    <div class="fd-grid" id="fd-grid">
      <!-- filled by JS -->
    </div>
    <div class="insight-box" id="insight-box"></div>
    <div>
      <div class="sparrate-row">
        <span class="sparrate-label">💰 Sparrate / Monat</span>
        <input type="number" class="sparrate-input" id="sparrate-input" placeholder="—" step="10"/>
        <span style="font-size:13px;color:var(--muted)">€</span>
        <button class="sparrate-save" id="sparrate-save-btn" onclick="saveSparrate()">Speichern</button>
      </div>
      <div style="font-size:11px;color:var(--muted);margin-top:6px" id="sparrate-hint"></div>
    </div>
  </div>

  <!-- Budget + Wartezeit -->
  <div class="budget-card">
    <div class="budget-row">
      <div class="budget-field">
        <span class="budget-label">Budget / Monat</span>
        <input type="number" class="budget-input" id="budget-input" value="500"/>
        <span class="budget-unit">€</span>
      </div>
      <div class="budget-field">
        <span class="budget-label">Wartezeit</span>
        <input type="number" class="budget-input" id="wait-input" value="30" style="width:48px"/>
        <span class="budget-unit">Tage</span>
      </div>
      <div class="budget-bar-wrap">
        <div class="budget-bar-labels">
          <span id="budget-spent-label">0€ ausgeplant</span>
          <span id="budget-left-label">500€ frei</span>
        </div>
        <div class="budget-bar-track">
          <div class="budget-bar-fill" id="budget-bar-fill" style="width:0%;background:var(--green)"></div>
        </div>
      </div>
    </div>
    <div class="budget-summary" id="budget-summary"></div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab-btn active" id="tab-wish" onclick="switchTab('wish')">🛒 Wunschliste</button>
    <button class="tab-btn" id="tab-plan" onclick="switchTab('plan')">📅 Geplante Ausgaben</button>
  </div>

  <!-- TAB: WUNSCHLISTE -->
  <div id="view-wish">
    <!-- Sort bar -->
    <div class="sort-bar">
      <span class="sort-label">Sortieren</span>
      <button class="sort-btn active" data-sort="score">Score</button>
      <button class="sort-btn" data-sort="price-asc">Preis ↑</button>
      <button class="sort-btn" data-sort="price-desc">Preis ↓</button>
      <button class="sort-btn" data-sort="cpd">Cost/Tag</button>
      <div class="spacer"></div>
      <span class="items-count" id="items-count">0 Artikel</span>
      <button class="add-btn" onclick="openModal()">+ Artikel</button>
    </div>
    <div class="tag-row" id="filter-row" style="margin-top:-4px"></div>
    <div class="items-grid" id="items-grid"></div>
    <div id="bought-section" hidden>
      <div class="section-title" style="margin-bottom:12px">✓ Gekauft</div>
      <div class="items-grid" id="bought-grid"></div>
    </div>
  </div>

  <!-- TAB: GEPLANTE AUSGABEN -->
  <div id="view-plan" hidden>
    <!-- Totals -->
    <div class="plan-total-bar">
      <div>
        <div class="plan-total-label">⚠️ Fällig in 30 Tagen</div>
        <div class="plan-total-val" id="plan-due-30">0 €</div>
        <div class="plan-total-sub" id="plan-due-30-sub"></div>
      </div>
      <div>
        <div class="plan-total-label">📋 Alle geplanten Ausgaben</div>
        <div class="plan-total-val" id="plan-total-all">0 €</div>
        <div class="plan-total-sub" id="plan-count-sub"></div>
      </div>
      <button class="add-btn" onclick="openPlanModal()">+ Ausgabe</button>
    </div>
    <div class="plan-list" id="plan-list" style="margin-top:4px"></div>
  </div>

</div><!-- end page -->

<!-- Plan Modal -->
<div class="plan-modal-overlay" id="plan-modal-overlay" onclick="if(event.target===this)closePlanModal()">
  <div class="plan-modal">
    <button class="modal-close" onclick="closePlanModal()">✕</button>
    <div class="modal-title" id="plan-modal-title">Ausgabe planen</div>
    <div class="field"><label>Name *</label><input type="text" id="p-name" placeholder="z.B. Urlaub Kroatien"/></div>
    <div class="two-col">
      <div class="field"><label>Betrag (€) *</label><input type="number" id="p-price" min="0" step="0.01" placeholder="700"/></div>
      <div class="field"><label>Fälligkeitsdatum *</label><input type="date" id="p-date"/></div>
    </div>
    <div class="two-col">
      <div class="field"><label>Emoji</label><input type="text" id="p-emoji" placeholder="✈️" maxlength="2"/></div>
      <div class="field"><label>Notiz</label><input type="text" id="p-note" placeholder="Anmerkung…"/></div>
    </div>
    <button class="modal-submit" onclick="savePlanItem()">Speichern</button>
  </div>
</div>

<!-- Wish Modal -->
<div class="modal-overlay" id="modal-overlay" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-title" id="modal-title">Artikel hinzufügen</div>

    <div class="field"><label>Name *</label><input type="text" id="f-name" placeholder="z.B. Favero Assioma DUO"/></div>

    <div class="field">
      <label>Bild</label>
      <div class="img-preview" id="img-preview" onclick="document.getElementById('f-img-file').click()">
        <div class="img-placeholder">🖼<br><span>Klicken oder URL unten</span></div>
      </div>
      <input type="file" id="f-img-file" accept="image/*" style="display:none" onchange="handleImgFile(event)"/>
      <input type="url" id="f-img-url" placeholder="Bild-URL…" oninput="handleImgUrl(this.value)" style="margin-top:6px;background:var(--s2);border:1.5px solid var(--border);border-radius:9px;padding:8px 12px;font-size:13px;color:var(--text);outline:none;width:100%"/>
    </div>

    <div class="two-col">
      <div class="field"><label>Preis (€) *</label><input type="number" id="f-price" min="0" step="0.01" placeholder="299.00"/></div>
      <div class="field"><label>Nutzungsdauer (Jahre)</label><input type="number" id="f-years" min="0.1" step="0.1" placeholder="3"/></div>
    </div>
    <div class="field"><label>Link</label><input type="url" id="f-link" placeholder="https://…"/></div>

    <div class="field">
      <label>Kategorie</label>
      <div class="tag-row" id="cat-tags">
        <button class="tag" onclick="selectTag(this,'Tech')">Tech</button>
        <button class="tag" onclick="selectTag(this,'Sport')">Sport</button>
        <button class="tag" onclick="selectTag(this,'Kleidung')">Kleidung</button>
        <button class="tag" onclick="selectTag(this,'Fahrrad')">Fahrrad</button>
        <button class="tag" onclick="selectTag(this,'Haushalt')">Haushalt</button>
        <button class="tag" onclick="selectTag(this,'Sonstiges')">Sonstiges</button>
      </div>
      <input type="text" id="f-cat-custom" placeholder="+ Eigene Kategorie" style="margin-top:6px;background:var(--s2);border:1.5px solid var(--border);border-radius:99px;padding:5px 12px;font-size:12px;color:var(--text);outline:none;width:auto"/>
    </div>

    <div class="field">
      <label>Prioritäts-Score</label>
      <div class="score-grid">
        <div class="score-row"><span class="score-name">🔥 Wunsch</span><input type="range" class="score-slider" id="s-want" min="1" max="10" value="5" oninput="updateScore()"/><span class="score-val" id="sv-want">5</span></div>
        <div class="score-row"><span class="score-name">⚡ Nutzen</span><input type="range" class="score-slider" id="s-use" min="1" max="10" value="5" oninput="updateScore()"/><span class="score-val" id="sv-use">5</span></div>
        <div class="score-row"><span class="score-name">💸 Budget-fit</span><input type="range" class="score-slider" id="s-budget" min="1" max="10" value="5" oninput="updateScore()"/><span class="score-val" id="sv-budget">5</span></div>
        <div class="score-row"><span class="score-name">⏳ Dringend</span><input type="range" class="score-slider" id="s-urgent" min="1" max="10" value="5" oninput="updateScore()"/><span class="score-val" id="sv-urgent">5</span></div>
        <div class="score-total"><span style="font-size:12px;color:var(--muted)">Gesamt-Score (max 100)</span><span class="score-val" id="score-total" style="font-size:20px">50</span></div>
      </div>
    </div>

    <div class="field"><label>Notiz</label><textarea id="f-note" placeholder="Warum willst du das?"></textarea></div>
    <button class="modal-submit" onclick="saveItem()">Speichern</button>
  </div>
</div>

<script>
// ── Config
const STORAGE_KEY = 'wunschliste_v2';
const WORKER_URL  = 'https://mvg-proxy.oskarherkt.workers.dev';
const SHEETS_ID   = '2PACX-1vTVvTiUbd-9gQBaui310DQVRglT85CYjuNxB5KRtRWTNZBEBnrEtoMI58I2_vi8qPz8oGCmgaf1Rjo9';
const SHEETS_GID  = '965386565';
const APPS_SCRIPT_URL = localStorage.getItem('apps_script_url') || '';

// ── GitHub Sync
const GH_OWNER = 'raksosuhl';
const GH_REPO  = 'raksosuhl.github.io';
const GH_FILE  = 'wunschliste-data.json';

function getGhToken() {
  let token = localStorage.getItem('gh_token');
  if (!token) {
    token = prompt('GitHub Token eingeben (einmalig, wird lokal gespeichert):');
    if (token) localStorage.setItem('gh_token', token.trim());
  }
  return token;
}

let ghFileSha = null; // needed for updates

async function ghLoad() {
  const token = getGhToken(); if (!token) return null;
  try {
    const res = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/contents/${GH_FILE}`, {
      headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' }
    });
    if (res.status === 404) return null;
    if (!res.ok) throw new Error('GitHub load failed: ' + res.status);
    const data = await res.json();
    ghFileSha = data.sha;
    return JSON.parse(atob(data.content.replace(/\n/g,'')));
  } catch(e) { console.warn('GitHub load error:', e); return null; }
}

async function ghSave(wishItems, planList) {
  const token = getGhToken(); if (!token) return;
  try {
    const payload = { items: wishItems ?? items, plan: planList ?? planItems, savedAt: Date.now() };
    const content = btoa(unescape(encodeURIComponent(JSON.stringify(payload, null, 2))));
    const body = { message: 'Update wunschliste', content };
    if (ghFileSha) body.sha = ghFileSha;
    const res = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/contents/${GH_FILE}`, {
      method: 'PUT',
      headers: { 'Authorization': `token ${token}`, 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (!res.ok) throw new Error('GitHub save failed: ' + res.status);
    const data = await res.json();
    ghFileSha = data.content.sha;
    showSyncStatus('✓ Synced', 'green');
  } catch(e) { console.warn('GitHub save error:', e); showSyncStatus('Sync-Fehler', 'red'); }
}

function showSyncStatus(msg, color) {
  let el = document.getElementById('sync-status');
  if (!el) {
    el = document.createElement('span');
    el.id = 'sync-status';
    el.style.cssText = 'font-size:11px;font-family:DM Mono,monospace;margin-left:8px;transition:opacity 1s';
    document.querySelector('.topbar-right').prepend(el);
  }
  el.textContent = msg;
  el.style.color  = color === 'green' ? 'var(--green)' : color === 'red' ? 'var(--red)' : 'var(--muted)';
  el.style.opacity = '1';
  setTimeout(() => el.style.opacity = '0', 3000);
}

async function syncInit() {
  showSyncStatus('⟳ Syncing…', 'neutral');
  const remote = await ghLoad();
  if (remote) {
    // Remote is the single source of truth – use it directly (last-write-wins)
    const remoteItems = remote.items || (Array.isArray(remote) ? remote : []);
    const remotePlan  = remote.plan  || [];
    const remoteTs    = remote.savedAt || 0;
    const localTs     = +localStorage.getItem('wl_savedAt') || 0;

    if (remoteTs >= localTs) {
      // Remote is newer → overwrite local
      items = remoteItems;
      planItems = remotePlan;
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      localStorage.setItem(PLAN_KEY, JSON.stringify(planItems));
    } else {
      // Local is newer → push to remote
      await ghSave(items, planItems);
    }
    renderAll();
    renderPlan();
    showSyncStatus('✓ Synced', 'green');
  } else if (items.length > 0 || planItems.length > 0) {
    await ghSave(items, planItems);
  } else {
    showSyncStatus('', 'neutral');
  }
}

// ── Finance state (loaded from Sheets)
let finance = { daily: null, spent: null, daysLeft: null, sparrate: null };

// ── Items
function loadItems() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; } catch { return []; } }
function saveItems(i) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(i));
  localStorage.setItem('wl_savedAt', Date.now());
  ghSave(i, planItems);
}
let items = loadItems();
let editId = null, currentImg = null, selectedCat = '', sortMode = 'score', filterCat = '';

// ── Budget / wait (local)
const budgetInput = document.getElementById('budget-input');
const waitInput   = document.getElementById('wait-input');
budgetInput.value = localStorage.getItem('wl_budget') || 500;
waitInput.value   = localStorage.getItem('wl_wait')   || 30;
budgetInput.addEventListener('input', () => { localStorage.setItem('wl_budget', budgetInput.value); renderAll(); });
waitInput.addEventListener('input',   () => { localStorage.setItem('wl_wait', waitInput.value); renderAll(); });
const getBudget   = () => parseFloat(budgetInput.value) || 500;
const getWaitDays = () => parseInt(waitInput.value) || 30;

// ── Fetch Sheets cell via Worker
async function fetchCell(range) {
  const url = `https://docs.google.com/spreadsheets/d/e/${SHEETS_ID}/pubhtml?gid=${SHEETS_GID}&single=true&chrome=false&widget=false&headers=false&range=${range}`;
  const res  = await fetch(`${WORKER_URL}/?url=${encodeURIComponent(url)}`, { signal: AbortSignal.timeout(8000) });
  const html = await res.text();
  const doc  = new DOMParser().parseFromString(html, 'text/html');
  const td   = doc.querySelector('td');
  return td ? td.textContent.trim() : null;
}

function parseNum(raw) {
  if (!raw) return NaN;
  return parseFloat(raw.replace(/[€\s\u00a0%]/g,'').replace('−','-').replace(',','.'));
}

async function loadFinance() {
  try {
    const [rawDaily, rawSpent, rawDaysLeft, rawSparrate] = await Promise.all([
      fetchCell('I38:I38'),
      fetchCell('I39:I39'),
      fetchCell('I40:I40'),
      fetchCell('L47:L47'),
    ]);
    finance.daily    = parseNum(rawDaily);
    finance.spent    = parseNum(rawSpent);
    finance.daysLeft = parseNum(rawDaysLeft);
    finance.sparrate = parseNum(rawSparrate);

    // Pre-fill sparrate input
    const sparInput = document.getElementById('sparrate-input');
    const saved = localStorage.getItem('sparrate_local');
    if (!isNaN(finance.sparrate) && !sparInput.value) sparInput.value = finance.sparrate.toFixed(0);
    else if (saved && !sparInput.value) sparInput.value = saved;

    updateFinanceUI();
    renderAll(); // re-render cards with can-buy badges
  } catch(e) {
    document.getElementById('fb-prog-label').textContent = 'Sheets nicht erreichbar';
  }
}

function updateFinanceUI() {
  const { daily, spent, daysLeft, sparrate } = finance;

  // Banner daily
  const fbDaily = document.getElementById('fb-daily');
  if (!isNaN(daily)) {
    fbDaily.textContent = (daily >= 0 ? '+' : '') + daily.toLocaleString('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2}) + '€';
    fbDaily.className = 'fb-val ' + (daily >= 20 ? 'great' : daily >= 5 ? 'good' : daily >= 0 ? 'neutral' : daily >= -10 ? 'warning' : 'negative');
  }

  // Banner sparrate
  const fbSpar = document.getElementById('fb-sparrate');
  const curSpar = parseFloat(document.getElementById('sparrate-input').value) || sparrate || 0;
  if (!isNaN(curSpar)) fbSpar.textContent = curSpar.toFixed(0) + '€/Mo';

  // Prognose: project end-of-month balance
  const progFill  = document.getElementById('fb-prog-fill');
  const progLabel = document.getElementById('fb-prog-label');
  if (!isNaN(spent) && !isNaN(daysLeft) && daysLeft > 0) {
    const projectedSpend = spent * daysLeft;
    const monthlyBudget  = getBudget();
    const pct = Math.min(100, (projectedSpend / monthlyBudget) * 100);
    progFill.style.width      = pct + '%';
    progFill.style.background = pct > 100 ? 'var(--red)' : pct > 80 ? 'var(--orange)' : 'var(--green)';
    const projected = monthlyBudget - projectedSpend;
    progLabel.textContent = projected >= 0
      ? `Prognose: +${projected.toFixed(0)}€ Ende Monat`
      : `Prognose: ${projected.toFixed(0)}€ Überzug`;
    progLabel.style.color = projected >= 0 ? 'var(--muted)' : 'var(--red)';
  }

  // Topbar subtitle
  const topSub = document.getElementById('topbar-sub');
  if (!isNaN(daysLeft)) topSub.textContent = `noch ${daysLeft} Tage im Monat`;

  // Detail panel
  const fdGrid = document.getElementById('fd-grid');
  fdGrid.innerHTML = [
    { label: '💰 Pro Tag verfügbar', val: isNaN(daily) ? '—' : (daily>=0?'+':'')+daily.toFixed(2)+'€', sub: daily>=0?'verfügbar':'überzogen', cls: daily>=20?'great':daily>=5?'good':daily>=0?'neutral':daily>=-10?'warning':'negative' },
    { label: '📊 Ausgaben / Tag', val: isNaN(spent) ? '—' : spent.toFixed(2)+'€', sub: 'Ø heute', cls: '' },
    { label: '📅 Tage verbleibend', val: isNaN(daysLeft) ? '—' : daysLeft, sub: 'im Monat', cls: '' },
    { label: '📈 Sparrate / Monat', val: isNaN(curSpar) ? '—' : curSpar.toFixed(0)+'€', sub: 'gespart & angelegt', cls: '' },
  ].map(s => `<div class="fd-stat"><div class="fd-label">${s.label}</div><div class="fd-val ${s.cls}">${s.val}</div><div class="fd-sub">${s.sub}</div></div>`).join('');

  // Insight box + Sparrate hint
  const insight = document.getElementById('insight-box');
  const sparHint = document.getElementById('sparrate-hint');
  if (!isNaN(spent) && !isNaN(daily) && !isNaN(daysLeft)) {
    const monthlyBudget  = getBudget();
    const projectedSpend = spent * daysLeft;
    const planned30      = planDue30Total();
    const projected      = monthlyBudget - projectedSpend - planned30;
    const isOverdrawn    = daily < 0;
    const topItem = getSorted(items.filter(i=>!i.bought))[0];

    if (isOverdrawn) {
      // Already in the red today
      insight.className = 'insight-box bad';
      insight.innerHTML = `⚠️ Du bist heute <strong>${Math.abs(daily).toFixed(2)}€ im Minus</strong>. Versuche die nächsten <strong>${daysLeft} Tage</strong> weniger auszugeben um den Monat auszugleichen.${topItem ? ` Kein Kauf von <strong>${topItem.name}</strong> diesen Monat.` : ''}`;
    } else if (projected < 0) {
      insight.className = 'insight-box warn';
      insight.innerHTML = `⚠️ Du gibst <strong>${spent.toFixed(2)}€/Tag</strong> aus – bei diesem Tempo endet der Monat mit <strong>${projected.toFixed(0)}€ Überzug</strong>. Reduziere auf max. <strong>${(monthlyBudget/30).toFixed(2)}€/Tag</strong>.`;
    } else {
      const monthsNeeded = topItem?.price && curSpar > 0 ? Math.ceil(topItem.price / curSpar) : null;
      insight.className = 'insight-box ok';
      insight.innerHTML = topItem && monthsNeeded
        ? `✓ Du bist auf Kurs. Du gibst <strong>${spent.toFixed(2)}€/Tag</strong> aus – Prognose <strong>+${projected.toFixed(0)}€</strong> am Monatsende${planned30>0?` (nach ${planned30.toFixed(0)}€ geplanten Ausgaben)`:''} . Für <strong>${topItem.name}</strong> (${topItem.price}€) sparst du noch <strong>${monthsNeeded} Monat${monthsNeeded!==1?'e':''}</strong>.`
        : `✓ Du bist auf Kurs – <strong>+${projected.toFixed(0)}€</strong> Prognose Monatsende${planned30>0?` (nach ${planned30.toFixed(0)}€ geplanten Ausgaben)`:''}. `;
    }

    // Sparrate hint
    if (topItem?.price) {
      const betterSpar = Math.ceil(topItem.price / 3);
      const diff = betterSpar - curSpar;
      sparHint.innerHTML = diff > 0
        ? `Mit <strong>${betterSpar}€/Mo</strong> (+${diff}€) erreichst du <strong>${topItem.name}</strong> in 3 Monaten und legst den Rest an.`
        : curSpar > 0 ? `Du erreichst <strong>${topItem.name}</strong> in <strong>${Math.ceil(topItem.price/curSpar)} Monat${Math.ceil(topItem.price/curSpar)!==1?'e':''}</strong> – leg den Rest langfristig an.` : '';
    }
  }
}

function toggleFinanceDetail() {
  const panel = document.getElementById('finance-detail');
  const chev  = document.getElementById('fb-chevron');
  panel.hidden = !panel.hidden;
  chev.classList.toggle('open', !panel.hidden);
}

function canBuyItem(item) {
  if (!item.price || isNaN(finance.daily)) return null;
  const { daily, spent, daysLeft, sparrate } = finance;
  const planned30 = planDue30Total();

  // If already in the red → can't buy anything
  if (daily < 0) {
    const spar = parseFloat(document.getElementById('sparrate-input')?.value) || sparrate || 0;
    const months = spar > 0 ? Math.ceil(item.price / spar) : null;
    return { can: false, months };
  }

  const monthlyBudget = getBudget();
  const projected = !isNaN(spent) && !isNaN(daysLeft)
    ? monthlyBudget - spent * daysLeft - planned30
    : daily * (daysLeft || 15) - planned30;

  if (item.price <= Math.max(0, projected)) return { can: true, months: 0 };

  const spar = parseFloat(document.getElementById('sparrate-input')?.value) || sparrate || 0;
  const months = spar > 0 ? Math.ceil(item.price / spar) : null;
  return { can: false, months };
}

// ── Score
function calcScore(item) {
  return Math.round((item.want||5)*3 + (item.use||5)*3 + (item.budgetFit||5)*2 + (item.urgent||5)*2);
}
function cpd(item) {
  if (!item.price || !item.years) return null;
  return item.price / (item.years * 365);
}
function waitRemaining(item) {
  if (!item.addedAt) return 0;
  return Math.max(0, Math.round(getWaitDays() - (Date.now()-item.addedAt)/86400000));
}

// ── Modal
function openModal(id=null) {
  editId = id; currentImg = null;
  const item = id ? items.find(i=>i.id===id) : null;
  document.getElementById('modal-title').textContent = id ? 'Bearbeiten' : 'Artikel hinzufügen';
  document.getElementById('f-name').value    = item?.name  || '';
  document.getElementById('f-price').value   = item?.price || '';
  document.getElementById('f-years').value   = item?.years || '';
  document.getElementById('f-link').value    = item?.link  || '';
  document.getElementById('f-note').value    = item?.note  || '';
  document.getElementById('f-img-url').value = (item?.img && !item.img.startsWith('data:')) ? item.img : '';
  document.getElementById('f-cat-custom').value = '';
  currentImg = item?.img || null; refreshImgPreview();
  selectedCat = item?.cat || '';
  document.querySelectorAll('#cat-tags .tag').forEach(t => t.classList.toggle('active', t.textContent===selectedCat));
  ['want','use','budget','urgent'].forEach(k => {
    document.getElementById('s-'+k).value = item ? (k==='budget'?item.budgetFit||5:item[k]||5) : 5;
  });
  updateScore();
  document.getElementById('modal-overlay').classList.add('open');
  document.getElementById('f-name').focus();
}
function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); }
function selectTag(el,cat) {
  selectedCat = selectedCat===cat ? '' : cat;
  document.querySelectorAll('#cat-tags .tag').forEach(t=>t.classList.toggle('active',t.textContent===selectedCat));
}
function updateScore() {
  ['want','use','budget','urgent'].forEach(k=>document.getElementById('sv-'+k).textContent=document.getElementById('s-'+k).value);
  document.getElementById('score-total').textContent =
    +document.getElementById('s-want').value*3 + +document.getElementById('s-use').value*3 +
    +document.getElementById('s-budget').value*2 + +document.getElementById('s-urgent').value*2;
}
function handleImgFile(e) {
  const f = e.target.files[0]; if(!f) return;
  const r = new FileReader(); r.onload=ev=>{currentImg=ev.target.result;refreshImgPreview()}; r.readAsDataURL(f);
}
function handleImgUrl(url) { if(url){currentImg=url;refreshImgPreview();} }
function refreshImgPreview() {
  const p = document.getElementById('img-preview');
  p.innerHTML = currentImg
    ? `<img src="${currentImg}" onerror="this.parentElement.innerHTML='<div class=img-placeholder>⚠️<br>Bild nicht ladbar</div>'"/>`
    : `<div class="img-placeholder">🖼<br><span>Klicken oder URL unten</span></div>`;
  p.onclick = ()=>document.getElementById('f-img-file').click();
}
function saveItem() {
  const name = document.getElementById('f-name').value.trim();
  const price = parseFloat(document.getElementById('f-price').value);
  if (!name) { document.getElementById('f-name').focus(); return; }
  const cat = document.getElementById('f-cat-custom').value.trim() || selectedCat || 'Sonstiges';
  const item = {
    id: editId || Date.now().toString(), name,
    price: isNaN(price)?null:price,
    years: parseFloat(document.getElementById('f-years').value)||null,
    link:  document.getElementById('f-link').value.trim()||null,
    note:  document.getElementById('f-note').value.trim()||null,
    cat, img: currentImg,
    want: +document.getElementById('s-want').value, use: +document.getElementById('s-use').value,
    budgetFit: +document.getElementById('s-budget').value, urgent: +document.getElementById('s-urgent').value,
    addedAt: editId?(items.find(i=>i.id===editId)?.addedAt||Date.now()):Date.now(),
    bought:  editId?(items.find(i=>i.id===editId)?.bought||false):false,
  };
  items = editId ? items.map(i=>i.id===editId?item:i) : [...items, item];
  saveItems(items); closeModal(); renderAll();
}

// ── Render
function getSorted(list) {
  const filtered = filterCat ? list.filter(i=>i.cat===filterCat) : list;
  return [...filtered].sort((a,b) => {
    if (sortMode==='score')      return calcScore(b)-calcScore(a);
    if (sortMode==='price-asc')  return (a.price||999999)-(b.price||999999);
    if (sortMode==='price-desc') return (b.price||0)-(a.price||0);
    if (sortMode==='cpd')        return (cpd(a)||999)-(cpd(b)||999);
    return 0;
  });
}

function renderCard(item, rank, isBought) {
  const score  = calcScore(item);
  const cpdVal = cpd(item);
  const wait   = waitRemaining(item);
  const isTop  = rank===1 && !isBought;
  const buy    = !isBought ? canBuyItem(item) : null;

  const imgHtml = item.img
    ? `<div class="item-img"><img src="${item.img}" loading="lazy" onerror="this.parentElement.innerHTML='🖼'"/></div>`
    : `<div class="item-img">${{Tech:'💻',Sport:'🏃',Kleidung:'👕',Fahrrad:'🚴',Haushalt:'🏠'}[item.cat]||'🛒'}</div>`;

  const rankBadge = rank ? `<div class="item-rank ${isTop?'top':''} ${isBought?'bought-rank':''}">${isTop?'★':rank}</div>` : '';

  const waitBadge = !isBought
    ? (wait>0 ? `<span class="badge wait">⏳ ${wait}d warten</span>` : `<span class="badge wait-done">✓ Wartezeit ok</span>`)
    : '';

  let buyBadge = '';
  if (buy !== null) {
    if (buy.can) {
      buyBadge = `<span class="badge can-buy">✓ Leistbar</span>`;
    } else if (buy.months !== null) {
      buyBadge = `<span class="badge months">📅 ~${buy.months} Mo. sparen</span>`;
    } else {
      buyBadge = `<span class="badge cant-buy">✗ Nicht jetzt</span>`;
    }
  }

  return `<div class="item-card ${isBought?'bought':''}" style="animation-delay:${(rank||1)*0.04}s">
    ${rankBadge}
    ${imgHtml}
    <div class="item-body">
      <div class="item-cat">${item.cat||''}</div>
      <div class="item-name">${item.name}</div>
      <div class="item-price-row">
        <span class="item-price">${item.price!=null?item.price.toLocaleString('de-DE',{minimumFractionDigits:0,maximumFractionDigits:0})+'€':'—'}</span>
        ${cpdVal?`<span class="item-cpd">${cpdVal.toFixed(2)}€/Tag</span>`:''}
      </div>
      <div class="item-score-bar"><div class="item-score-fill" style="width:${score}%"></div></div>
      <div class="item-meta"><span class="item-score-label">Score</span><span class="item-score-val">${score}/100</span></div>
      <div class="item-badges">${waitBadge}${buyBadge}</div>
      ${item.note?`<div class="item-note">${item.note}</div>`:''}
    </div>
    <div class="item-actions">
      ${item.link?`<a href="${item.link}" target="_blank" class="item-btn">🔗</a>`:''}
      <button class="item-btn" onclick="openModal('${item.id}')">✏️</button>
      ${!isBought?`<button class="item-btn buy" onclick="markBought('${item.id}')">✓</button>`:`<button class="item-btn" onclick="markBought('${item.id}')">↩</button>`}
      <button class="item-btn danger" onclick="deleteItem('${item.id}')">🗑</button>
    </div>
  </div>`;
}

function renderAll() {
  const active = items.filter(i=>!i.bought);
  const bought = items.filter(i=>i.bought);
  const sorted = getSorted(active);

  // Budget bar
  const budget = getBudget();
  const total  = active.reduce((s,i)=>s+(i.price||0),0);
  const pct    = Math.min(100, budget>0?(total/budget)*100:0);
  const fill   = document.getElementById('budget-bar-fill');
  fill.style.width      = pct+'%';
  fill.style.background = pct>100?'var(--red)':pct>75?'var(--orange)':'var(--green)';
  document.getElementById('budget-spent-label').textContent = total.toFixed(0)+'€ ausgeplant';
  document.getElementById('budget-left-label').textContent  = Math.max(0,budget-total).toFixed(0)+'€ frei';

  // Budget summary + affordability
  const affordable = sorted.filter(i=>(i.price||0)<=budget);
  const canBuyNow  = sorted.filter(i=>canBuyItem(i)?.can);
  const summaryEl  = document.getElementById('budget-summary');
  if (canBuyNow.length>0) {
    summaryEl.innerHTML = `💚 <strong>${canBuyNow[0].name}</strong> (Prio #1) liegt im Budget – du könntest es dir jetzt leisten.`;
  } else if (affordable.length>0) {
    summaryEl.innerHTML = `<strong>${affordable[0].name}</strong> passt ins Monatslimit.`;
  } else { summaryEl.textContent = ''; }

  // Filter tags
  const allCats = [...new Set(items.map(i=>i.cat).filter(Boolean))];
  document.getElementById('filter-row').innerHTML = allCats.map(c=>
    `<button class="filter-tag ${filterCat===c?'active':''}" onclick="setFilter('${c}')">${c}</button>`
  ).join('') + (filterCat?`<button class="filter-tag active" onclick="setFilter('')">✕ Alle</button>`:'');

  document.getElementById('items-count').textContent = `${sorted.length} Artikel`;

  const grid = document.getElementById('items-grid');
  if (sorted.length===0) {
    grid.innerHTML = `<div class="empty"><div class="empty-icon">🛒</div><div class="empty-title">Noch nichts auf der Liste</div><div style="font-size:12px;color:var(--muted);max-width:260px">Füge deinen ersten Wunsch hinzu und lass den Score entscheiden was zuerst kommt.</div></div>`;
  } else {
    grid.innerHTML = sorted.map((item,i)=>renderCard(item,i+1,false)).join('');
  }

  const boughtSection = document.getElementById('bought-section');
  const boughtGrid    = document.getElementById('bought-grid');
  if (bought.length>0) { boughtSection.hidden=false; boughtGrid.innerHTML=bought.map(item=>renderCard(item,null,true)).join(''); }
  else { boughtSection.hidden=true; }

  // Update finance insight if data available
  if (finance.daily !== null) updateFinanceUI();
}

function markBought(id) {
  items = items.map(i=>i.id===id?{...i,bought:!i.bought}:i);
  saveItems(items); renderAll();
}
function deleteItem(id) {
  if (!confirm('Wirklich löschen?')) return;
  items = items.filter(i=>i.id!==id);
  saveItems(items); renderAll();
}
function setFilter(cat) { filterCat=cat; renderAll(); }

// Sort buttons
document.querySelectorAll('.sort-btn').forEach(btn => {
  btn.addEventListener('click', ()=>{
    sortMode=btn.dataset.sort;
    document.querySelectorAll('.sort-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active'); renderAll();
  });
});

// ── Sparrate save
async function saveSparrate() {
  const val = document.getElementById('sparrate-input').value;
  const btn = document.getElementById('sparrate-save-btn');
  localStorage.setItem('sparrate_local', val);
  finance.sparrate = parseFloat(val);
  updateFinanceUI(); renderAll();

  if (!APPS_SCRIPT_URL) {
    const url = prompt('Apps Script Web App URL eingeben:');
    if (url) { localStorage.setItem('apps_script_url', url); }
    btn.textContent='Gespeichert'; btn.classList.add('saved');
    setTimeout(()=>{btn.textContent='Speichern';btn.classList.remove('saved')},2000);
    return;
  }
  try {
    btn.textContent='…';
    await fetch(`${APPS_SCRIPT_URL}?sparrate=${encodeURIComponent(val)}`,{mode:'no-cors'});
    btn.textContent='✓'; btn.classList.add('saved');
    setTimeout(()=>{btn.textContent='Speichern';btn.classList.remove('saved')},2000);
  } catch { btn.textContent='Fehler'; setTimeout(()=>{btn.textContent='Speichern'},2000); }
}

// ── Theme
const tt = document.getElementById('theme-toggle');
const sv2 = localStorage.getItem('theme'), sa2 = +localStorage.getItem('themeSetAt')||0;
if (sv2 && Date.now()-sa2<86400000) { if(sv2==='dark') document.body.classList.add('dark'); }
else { if(new Date().getHours()>=20||new Date().getHours()<7) document.body.classList.add('dark'); }
tt.addEventListener('click',()=>{
  document.body.classList.toggle('dark');
  const d=document.body.classList.contains('dark');
  localStorage.setItem('theme',d?'dark':'light');
  localStorage.setItem('themeSetAt',Date.now());
});

// ── Tab switching
function switchTab(tab) {
  document.getElementById('view-wish').hidden = tab !== 'wish';
  document.getElementById('view-plan').hidden = tab !== 'plan';
  document.getElementById('tab-wish').classList.toggle('active', tab === 'wish');
  document.getElementById('tab-plan').classList.toggle('active', tab === 'plan');
  if (tab === 'plan') renderPlan();
}

// ── Planned expenses
const PLAN_KEY = 'ausgaben_plan_v1';
function loadPlan() { try { return JSON.parse(localStorage.getItem(PLAN_KEY)) || []; } catch { return []; } }
function savePlan(p) {
  localStorage.setItem(PLAN_KEY, JSON.stringify(p));
  localStorage.setItem('wl_savedAt', Date.now());
  ghSave(items, p);
}
let planItems = loadPlan();
let editPlanId = null;

function daysUntil(dateStr) {
  const today = new Date(); today.setHours(0,0,0,0);
  const target = new Date(dateStr);
  return Math.round((target - today) / 86400000);
}

// Sum of plan items due within 30 days (used in finance calc)
function planDue30Total() {
  return planItems
    .filter(p => { const d = daysUntil(p.date); return d >= 0 && d <= 30; })
    .reduce((s,p) => s + (p.price||0), 0);
}

function renderPlan() {
  const sorted = [...planItems].sort((a,b) => new Date(a.date)-new Date(b.date));
  const total30 = planDue30Total();
  const totalAll = planItems.reduce((s,p)=>s+(p.price||0),0);

  document.getElementById('plan-due-30').textContent = total30.toLocaleString('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2}) + ' €';
  document.getElementById('plan-total-all').textContent = totalAll.toLocaleString('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2}) + ' €';
  document.getElementById('plan-due-30-sub').textContent = total30 > 0 ? 'reduziert dein verfügbares Budget' : 'Nichts fällig';
  document.getElementById('plan-count-sub').textContent = `${planItems.length} geplante Ausgabe${planItems.length!==1?'n':''}`;

  const list = document.getElementById('plan-list');
  if (sorted.length === 0) {
    list.innerHTML = `<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px">Keine geplanten Ausgaben</div>`;
    return;
  }

  list.innerHTML = sorted.map(p => {
    const days = daysUntil(p.date);
    const urgencyClass = days < 0 ? 'ok' : days <= 7 ? 'urgent' : days <= 30 ? 'soon' : 'ok';
    const daysLabel = days < 0 ? 'vergangen' : days === 0 ? 'Heute' : days === 1 ? 'Morgen' : `in ${days} Tagen`;
    const daysClass = days < 0 ? 'ok' : days <= 7 ? 'urgent' : days <= 30 ? 'soon' : 'future';
    const dateFormatted = new Date(p.date).toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'});

    return `<div class="plan-item ${urgencyClass}">
      <div class="plan-emoji">${p.emoji||'📋'}</div>
      <div class="plan-body">
        <div class="plan-name">${p.name}</div>
        <div class="plan-date">${dateFormatted}${p.note ? ' · ' + p.note : ''}</div>
      </div>
      <span class="plan-days ${daysClass}">${daysLabel}</span>
      <div class="plan-price">${(p.price||0).toLocaleString('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2})} €</div>
      <div class="plan-actions">
        <button class="item-btn" onclick="openPlanModal('${p.id}')" style="padding:5px 8px">✏️</button>
        <button class="item-btn danger" onclick="deletePlanItem('${p.id}')" style="padding:5px 8px">🗑</button>
      </div>
    </div>`;
  }).join('');
}

function openPlanModal(id=null) {
  editPlanId = id;
  const p = id ? planItems.find(x=>x.id===id) : null;
  document.getElementById('plan-modal-title').textContent = id ? 'Ausgabe bearbeiten' : 'Ausgabe planen';
  document.getElementById('p-name').value  = p?.name  || '';
  document.getElementById('p-price').value = p?.price || '';
  document.getElementById('p-date').value  = p?.date  || '';
  document.getElementById('p-emoji').value = p?.emoji || '';
  document.getElementById('p-note').value  = p?.note  || '';
  document.getElementById('plan-modal-overlay').classList.add('open');
  document.getElementById('p-name').focus();
}
function closePlanModal() { document.getElementById('plan-modal-overlay').classList.remove('open'); }

function savePlanItem() {
  const name  = document.getElementById('p-name').value.trim();
  const price = parseFloat(document.getElementById('p-price').value);
  const date  = document.getElementById('p-date').value;
  if (!name || !date) return;
  const item = {
    id:    editPlanId || Date.now().toString(),
    name, price: isNaN(price)?0:price, date,
    emoji: document.getElementById('p-emoji').value.trim() || '📋',
    note:  document.getElementById('p-note').value.trim() || '',
  };
  planItems = editPlanId ? planItems.map(p=>p.id===editPlanId?item:p) : [...planItems, item];
  savePlan(planItems);
  closePlanModal();
  renderPlan();
  updateFinanceUI(); // recalc with new planned costs
}

function deletePlanItem(id) {
  if (!confirm('Löschen?')) return;
  planItems = planItems.filter(p=>p.id!==id);
  savePlan(planItems);
  renderPlan();
  updateFinanceUI();
}

// ── Init
renderAll();
loadFinance();
syncInit();
</script>
</body>
</html>
